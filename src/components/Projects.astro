---
import { siteConfig } from "../config/site";
---

<section id="projects" class="section-padding border-t border-navy-800/30">
  <div class="section-container">
    <div class="fade-in mb-12">
      <p class="text-sm font-medium text-accent-blue uppercase tracking-widest mb-3">
        Projects
      </p>
      <h2 class="text-3xl sm:text-4xl font-bold text-white tracking-tight">
        Selected Work
      </h2>
      <p class="mt-3 text-navy-400 max-w-xl">
        Representative projects showcasing expertise in payment systems,
        backend architecture, and DevOps.
      </p>
    </div>

    <!-- Coming Soon -->
    <div class="fade-in card flex flex-col items-center justify-center text-center py-16 sm:py-20">
      <div class="w-14 h-14 rounded-xl bg-navy-800 border border-navy-700/50 flex items-center justify-center mb-6">
        <svg class="w-7 h-7 text-accent-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
        </svg>
      </div>
      <h3 class="text-xl font-semibold text-white mb-2">Coming Soon</h3>
      <p class="text-sm text-navy-400 max-w-md leading-relaxed">
        I'm currently curating my project portfolio. Check back soon for detailed case studies on payment systems, microservice architectures, and DevOps tooling.
      </p>
    </div>
  </div>
</section>
