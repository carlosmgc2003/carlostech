---
import { siteConfig } from "../config/site";

const iconPaths: Record<string, string> = {
  server:
    "M5 12H3a1 1 0 01-1-1V5a1 1 0 011-1h18a1 1 0 011 1v6a1 1 0 01-1 1h-2M5 12H3a1 1 0 00-1 1v6a1 1 0 001 1h18a1 1 0 001-1v-6a1 1 0 00-1-1h-2M5 12h14",
  "credit-card":
    "M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z",
  network:
    "M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z",
  shield:
    "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z",
  cloud:
    "M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z",
};
---

<section id="expertise" class="section-padding border-t border-navy-800/30">
  <div class="section-container">
    <div class="fade-in mb-12">
      <p class="text-sm font-medium text-accent-blue uppercase tracking-widest mb-3">
        Expertise
      </p>
      <h2 class="text-3xl sm:text-4xl font-bold text-white tracking-tight">
        What I Do
      </h2>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-5">
      {
        siteConfig.expertise.map((item) => (
          <div class="fade-in card group">
            <div class="w-10 h-10 rounded-lg bg-navy-800 border border-navy-700/50 flex items-center justify-center mb-4 group-hover:border-accent-blue/30 transition-colors">
              <svg
                class="w-5 h-5 text-accent-blue"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.5"
                  d={iconPaths[item.icon] || iconPaths.server}
                />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-white mb-2">{item.title}</h3>
            <p class="text-sm text-navy-400 leading-relaxed">
              {item.description}
            </p>
          </div>
        ))
      }
    </div>

    <!-- Experience Timeline -->
    <div class="fade-in mt-20">
      <h3
        class="text-sm font-medium text-navy-500 uppercase tracking-widest mb-8"
      >
        Experience
      </h3>
      <div class="space-y-0">
        {
          siteConfig.experience.map((exp, i) => (
            <div class="fade-in relative pl-8 pb-8 border-l border-navy-700/50 last:pb-0">
              <div class="absolute -left-[5px] top-1 w-2.5 h-2.5 rounded-full bg-navy-700 border-2 border-navy-950" />
              <div class="flex flex-col sm:flex-row sm:items-baseline sm:gap-4">
                <h4 class="text-base font-medium text-white">{exp.role}</h4>
                <div class="flex items-center gap-2 text-sm text-navy-500">
                  <span>{exp.company}</span>
                  <span>·</span>
                  <span>{exp.period}</span>
                </div>
              </div>
              <p class="mt-1 text-sm text-navy-400">{exp.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
