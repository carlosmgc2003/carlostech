---
import { siteConfig } from "../config/site";
import { t, tArray } from "../i18n";
import type { Locale } from "../i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const paragraphs = tArray(locale, "aboutParagraphs");
const focusItems = tArray(locale, "aboutFocusItems");
---

<section id="about" class="section-padding border-t border-navy-800/30">
  <div class="section-container">
    <div class="fade-in mb-12">
      <p class="text-sm font-medium text-accent-blue uppercase tracking-widest mb-3">
        {t(locale, "aboutLabel")}
      </p>
      <h2 class="text-3xl sm:text-4xl font-bold text-white tracking-tight">
        {t(locale, "aboutHeading")}
      </h2>
    </div>

    <div class="grid lg:grid-cols-5 gap-12 lg:gap-16">
      <!-- Left: Text -->
      <div class="lg:col-span-3 space-y-5">
        {
          paragraphs.map((paragraph) => (
            <p class="fade-in text-navy-300 leading-relaxed">{paragraph}</p>
          ))
        }
      </div>

      <!-- Right: Highlights -->
      <div class="lg:col-span-2">
        <div class="fade-in card space-y-5">
          <h3 class="text-sm font-medium text-navy-400 uppercase tracking-wider">
            {t(locale, "aboutCoreFocus")}
          </h3>
          <ul class="space-y-3">
            {
              focusItems.map((item) => (
                <li class="flex items-start gap-3 text-sm text-navy-200">
                  <svg
                    class="w-4 h-4 mt-0.5 text-accent-blue shrink-0"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M9 12l2 2 4-4"
                    />
                  </svg>
                  {item}
                </li>
              ))
            }
          </ul>

          <div class="pt-4 border-t border-navy-700/50">
            <p class="text-xs text-navy-500">
              {t(locale, "aboutEducation")}
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
