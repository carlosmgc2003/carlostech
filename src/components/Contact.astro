---
import { siteConfig } from "../config/site";
import { t } from "../i18n";
import type { Locale } from "../i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const contactLinks = [
  {
    label: t(locale, "contactEmail"),
    value: siteConfig.email,
    href: `mailto:${siteConfig.email}`,
    icon: "M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z",
  },
  {
    label: t(locale, "contactLinkedIn"),
    value: "Carlos Maceira Garcia Coni",
    href: siteConfig.linkedin,
    icon: "M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2zM4 6a2 2 0 100-4 2 2 0 000 4z",
  },
  {
    label: t(locale, "contactGitHub"),
    value: "carlosmgc2003",
    href: siteConfig.github,
    icon: "M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 00-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0020 4.77 5.07 5.07 0 0019.91 1S18.73.65 16 2.48a13.38 13.38 0 00-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 005 4.77a5.44 5.44 0 00-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 009 18.13V22",
  },
];
---

<section id="contact" class="section-padding border-t border-navy-800/30">
  <div class="section-container">
    <div class="max-w-2xl mx-auto text-center">
      <div class="fade-in mb-10">
        <p
          class="text-sm font-medium text-accent-blue uppercase tracking-widest mb-3"
        >
          {t(locale, "contactLabel")}
        </p>
        <h2 class="text-3xl sm:text-4xl font-bold text-white tracking-tight">
          {t(locale, "contactHeading")}
        </h2>
        <p class="mt-3 text-navy-400">
          {t(locale, "contactDescription")}
        </p>
      </div>

      <div class="fade-in space-y-4">
        {
          contactLinks.map((link) => (
            <a
              href={link.href}
              target={link.label !== "Email" ? "_blank" : undefined}
              rel={link.label !== "Email" ? "noopener noreferrer" : undefined}
              class="card flex items-center gap-4 text-left hover:border-accent-blue/30"
            >
              <div class="w-10 h-10 rounded-lg bg-navy-800 border border-navy-700/50 flex items-center justify-center shrink-0">
                <svg
                  class="w-5 h-5 text-accent-blue"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="1.5"
                    d={link.icon}
                  />
                </svg>
              </div>
              <div>
                <p class="text-xs text-navy-500 uppercase tracking-wider">
                  {link.label}
                </p>
                <p class="text-sm text-navy-200">{link.value}</p>
              </div>
              <svg
                class="w-4 h-4 text-navy-600 ml-auto"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.5"
                  d="M9 5l7 7-7 7"
                />
              </svg>
            </a>
          ))
        }
      </div>

      <p class="fade-in mt-8 text-sm text-navy-500">
        {siteConfig.domain}
      </p>
    </div>
  </div>
</section>
