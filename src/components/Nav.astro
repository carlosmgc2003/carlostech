---
import { siteConfig } from "../config/site";
import { t } from "../i18n";
import type { Locale } from "../i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const navLinks = [
  { label: t(locale, "navAbout"), href: "#about" },
  { label: t(locale, "navStack"), href: "#stack" },
  { label: t(locale, "navExpertise"), href: "#expertise" },
  { label: t(locale, "navProjects"), href: "#projects" },
  { label: t(locale, "navContact"), href: "#contact" },
];

const otherLocale = locale === "es-AR" ? "en" : "es-AR";
const toggleLabel = locale === "es-AR" ? "EN" : "ES";
---

<header
  id="nav"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <nav
    class="section-container flex items-center justify-between h-16 sm:h-18"
  >
    <!-- Logo -->
    <a
      href="/"
      class="font-bold text-lg tracking-tight transition-colors duration-200"
      style="color: var(--text-heading);"
    >
      {siteConfig.shortName}<span style="color: var(--accent-gold);">.</span>
    </a>

    <!-- Desktop Nav -->
    <div class="hidden md:flex items-center gap-6">
      <ul class="flex items-center gap-6">
        {
          navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm font-medium transition-colors duration-200 nav-link"
                style="color: var(--text-muted);"
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>

      <!-- Language Toggle -->
      <button
        id="lang-toggle-desktop"
        data-locale={otherLocale}
        class="badge cursor-pointer hover:border-[var(--accent-primary)]"
        aria-label={`Switch to ${otherLocale === "es-AR" ? "Spanish" : "English"}`}
      >
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
        </svg>
        {toggleLabel}
      </button>

      <!-- Theme Toggle -->
      <button
        id="theme-toggle-desktop"
        class="theme-toggle"
        aria-label="Toggle color scheme"
      >
        <!-- Sun icon — shown in dark mode -->
        <svg class="icon-sun w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
            d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z" />
        </svg>
        <!-- Moon icon — shown in light mode -->
        <svg class="icon-moon w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
            d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z" />
        </svg>
      </button>
    </div>

    <!-- Mobile Controls -->
    <div class="flex md:hidden items-center gap-3">
      <!-- Mobile Language Toggle -->
      <button
        id="lang-toggle-mobile"
        data-locale={otherLocale}
        class="badge cursor-pointer text-[0.65rem] px-2 py-0.5"
        aria-label={`Switch to ${otherLocale === "es-AR" ? "Spanish" : "English"}`}
      >
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
        </svg>
        {toggleLabel}
      </button>

      <!-- Mobile Theme Toggle -->
      <button
        id="theme-toggle-mobile"
        class="theme-toggle !w-8 !h-8"
        aria-label="Toggle color scheme"
      >
        <svg class="icon-sun w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
            d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z" />
        </svg>
        <svg class="icon-moon w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
            d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z" />
        </svg>
      </button>

      <!-- Hamburger -->
      <button
        id="mobile-menu-btn"
        class="transition-colors"
        style="color: var(--text-muted);"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path
            id="menu-icon"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.5"
            d="M4 6h16M4 12h16M4 18h16"
          ></path>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="md:hidden hidden backdrop-blur-lg border-b"
    style="background-color: color-mix(in srgb, var(--bg-surface) 96%, transparent); border-color: var(--border);"
  >
    <ul class="section-container py-4 space-y-1">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="mobile-nav-link block py-2.5 text-sm font-medium transition-colors"
              style="color: var(--text-muted);"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</header>

<script>
  // ── Mobile menu toggle ────────────────────────────────────────
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");

  btn?.addEventListener("click", () => {
    const isOpen = !menu?.classList.contains("hidden");
    menu?.classList.toggle("hidden");
    btn?.setAttribute("aria-expanded", String(!isOpen));
  });

  document.querySelectorAll(".mobile-nav-link").forEach((link) => {
    link.addEventListener("click", () => {
      menu?.classList.add("hidden");
      btn?.setAttribute("aria-expanded", "false");
    });
  });

  // ── Nav scroll effect ─────────────────────────────────────────
  const nav = document.getElementById("nav");
  window.addEventListener("scroll", () => {
    if (window.scrollY > 50) {
      nav?.classList.add("nav-scrolled");
    } else {
      nav?.classList.remove("nav-scrolled");
    }
  });

  // ── Language toggle ───────────────────────────────────────────
  document.querySelectorAll("#lang-toggle-desktop, #lang-toggle-mobile").forEach((toggle) => {
    toggle.addEventListener("click", () => {
      const target = (toggle as HTMLElement).dataset.locale;
      document.cookie = `lang=${target}; path=/; max-age=${60 * 60 * 24 * 365}; SameSite=Lax`;
      window.location.reload();
    });
  });

  // ── Theme toggle ──────────────────────────────────────────────
  function applyTheme(isDark: boolean) {
    document.documentElement.classList.toggle("dark", isDark);
    document.documentElement.classList.toggle("light", !isDark);
    localStorage.setItem("theme", isDark ? "dark" : "light");
  }

  document.querySelectorAll("#theme-toggle-desktop, #theme-toggle-mobile").forEach((toggle) => {
    toggle.addEventListener("click", () => {
      const isDark = document.documentElement.classList.contains("dark");
      applyTheme(!isDark);
    });
  });

  // Nav link hover style (CSS variable can't be used in Tailwind hover easily)
  document.querySelectorAll(".nav-link").forEach((link) => {
    link.addEventListener("mouseenter", () => {
      (link as HTMLElement).style.color = "var(--text-heading)";
    });
    link.addEventListener("mouseleave", () => {
      (link as HTMLElement).style.color = "var(--text-muted)";
    });
  });
</script>
