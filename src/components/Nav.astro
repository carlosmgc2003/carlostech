---
import { siteConfig } from "../config/site";

const navLinks = [
  { label: "About", href: "#about" },
  { label: "Stack", href: "#stack" },
  { label: "Expertise", href: "#expertise" },
  { label: "Projects", href: "#projects" },
  { label: "Contact", href: "#contact" },
];
---

<header
  id="nav"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <nav
    class="section-container flex items-center justify-between h-16 sm:h-18"
  >
    <a
      href="/"
      class="text-white font-semibold text-lg tracking-tight hover:text-accent-blue transition-colors"
    >
      {siteConfig.shortName}<span class="text-accent-blue">.</span>
    </a>

    <!-- Desktop Nav -->
    <ul class="hidden md:flex items-center gap-8">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="text-sm text-navy-300 hover:text-white transition-colors duration-200"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden text-navy-300 hover:text-white transition-colors"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <svg
        class="w-6 h-6"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          id="menu-icon"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="1.5"
          d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
  </nav>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="md:hidden hidden bg-navy-900/95 backdrop-blur-lg border-b border-navy-700/50"
  >
    <ul class="section-container py-4 space-y-1">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="mobile-nav-link block py-2.5 text-sm text-navy-300 hover:text-white transition-colors"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</header>

<script>
  // Mobile menu toggle
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");

  btn?.addEventListener("click", () => {
    const isOpen = !menu?.classList.contains("hidden");
    menu?.classList.toggle("hidden");
    btn?.setAttribute("aria-expanded", String(!isOpen));
  });

  // Close mobile menu on link click
  document.querySelectorAll(".mobile-nav-link").forEach((link) => {
    link.addEventListener("click", () => {
      menu?.classList.add("hidden");
      btn?.setAttribute("aria-expanded", "false");
    });
  });

  // Nav background on scroll
  const nav = document.getElementById("nav");
  window.addEventListener("scroll", () => {
    if (window.scrollY > 50) {
      nav?.classList.add("bg-navy-950/90", "backdrop-blur-lg", "border-b", "border-navy-800/50");
    } else {
      nav?.classList.remove("bg-navy-950/90", "backdrop-blur-lg", "border-b", "border-navy-800/50");
    }
  });
</script>
